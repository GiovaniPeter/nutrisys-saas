generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  NUTRITIONIST
  SECRETARY
  ADMIN
  PROFESSIONAL
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED
  NO_SHOW
}

enum Sex {
  MALE
  FEMALE
  OTHER
  UNINFORMED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  PENDING
  PAID
  CANCELED
}

enum FoodDiaryStatus {
  PENDING
  APPROVED
  NEEDS_ADJUSTMENT
}

enum ChatSender {
  PROFESSIONAL
  PATIENT
}

model Organization {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  document       String?
  phone          String?
  address        String?
  primaryColor   String   @default("#00b894")
  secondaryColor String   @default("#6c5ce7")
  logoUrl        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users                   User[]
  patients                Patient[]
  appointments            Appointment[]
  subscriptions           Subscription[]
  foods                   Food[]
  mealPlans               MealPlan[]
  recipes                 Recipe[]
  recalls                 Recall[]
  labExams                LabExam[]
  supplementPrescriptions SupplementPrescription[]
  foodDiaryEntries        FoodDiaryEntry[]
  hydrationLogs           HydrationLog[]
  patientGoals            PatientGoal[]
  chatMessages            ChatMessage[]
  energyCalculations      EnergyCalculation[]
  educationalMaterials    EducationalMaterial[]
  transactions            FinancialTransaction[]
  auditLogs               AuditLog[]
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String   @unique
  passwordHash   String
  role           UserRole @default(NUTRITIONIST)
  crn            String?
  specialty      String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointments Appointment[] @relation("AppointmentProfessional")
  auditLogs    AuditLog[]

  @@index([organizationId])
}

model Subscription {
  id                  String             @id @default(cuid())
  organizationId      String
  planCode            String
  status              SubscriptionStatus @default(TRIALING)
  provider            String?
  providerCustomerId  String?
  providerSubId       String?
  trialEndsAt         DateTime?
  currentPeriodEndsAt DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
}

model Patient {
  id               String    @id @default(cuid())
  organizationId   String
  name             String
  email            String?
  phone            String?
  birthDate        DateTime?
  sex              Sex       @default(UNINFORMED)
  heightCm         Decimal?  @db.Decimal(6, 2)
  weightKg         Decimal?  @db.Decimal(6, 2)
  goal             String?
  notes            String?
  lgpdConsentAt    DateTime?
  portalAccessCode String?   @unique
  portalEnabled    Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointments            Appointment[]
  mealPlans               MealPlan[]
  bodyRecords             BodyRecord[]
  anamneses               Anamnesis[]
  recalls                 Recall[]
  labExams                LabExam[]
  supplementPrescriptions SupplementPrescription[]
  foodDiaryEntries        FoodDiaryEntry[]
  hydrationLogs           HydrationLog[]
  goals                   PatientGoal[]
  chatMessages            ChatMessage[]
  energyCalculations      EnergyCalculation[]
  transactions            FinancialTransaction[]

  @@index([organizationId])
  @@index([organizationId, name])
}

model Appointment {
  id             String            @id @default(cuid())
  organizationId String
  patientId      String
  professionalId String?
  startsAt       DateTime
  endsAt         DateTime?
  type           String
  status         AppointmentStatus @default(PENDING)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional User?        @relation("AppointmentProfessional", fields: [professionalId], references: [id], onDelete: SetNull)

  @@index([organizationId, startsAt])
  @@index([patientId])
}

model Food {
  id               String   @id @default(cuid())
  organizationId   String?
  name             String
  portion          String
  householdMeasure String?
  calories         Decimal  @db.Decimal(8, 2)
  protein          Decimal  @db.Decimal(8, 2)
  carbs            Decimal  @db.Decimal(8, 2)
  fat              Decimal  @db.Decimal(8, 2)
  fiber            Decimal? @db.Decimal(8, 2)
  category         String?
  source           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([name])
}

model MealPlan {
  id             String    @id @default(cuid())
  organizationId String
  patientId      String
  name           String
  targetCalories Int?
  targetProtein  Decimal?  @db.Decimal(8, 2)
  targetCarbs    Decimal?  @db.Decimal(8, 2)
  targetFat      Decimal?  @db.Decimal(8, 2)
  observations   String?
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  meals        Meal[]

  @@index([organizationId])
  @@index([patientId])
}

model Meal {
  id         String  @id @default(cuid())
  mealPlanId String
  type       String
  label      String
  time       String?
  position   Int     @default(0)

  mealPlan MealPlan   @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  items    MealItem[]

  @@index([mealPlanId])
}

model MealItem {
  id       String  @id @default(cuid())
  mealId   String
  foodName String
  portion  String
  quantity Decimal @db.Decimal(8, 2)
  calories Decimal @db.Decimal(8, 2)
  protein  Decimal @db.Decimal(8, 2)
  carbs    Decimal @db.Decimal(8, 2)
  fat      Decimal @db.Decimal(8, 2)
  notes    String?

  meal Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([mealId])
}

model Recipe {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  category       String?
  prepTimeMin    Int?
  servings       Int      @default(1)
  difficulty     String?
  tags           String[] @default([])
  steps          String[] @default([])
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ingredients  RecipeIngredient[]

  @@index([organizationId, name])
  @@index([organizationId, category])
}

model RecipeIngredient {
  id       String   @id @default(cuid())
  recipeId String
  foodId   String?
  foodName String
  portion  String
  quantity Decimal  @db.Decimal(8, 2)
  calories Decimal  @db.Decimal(8, 2)
  protein  Decimal  @db.Decimal(8, 2)
  carbs    Decimal  @db.Decimal(8, 2)
  fat      Decimal  @db.Decimal(8, 2)
  fiber    Decimal? @db.Decimal(8, 2)
  position Int      @default(0)
  notes    String?

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([foodId])
}

model BodyRecord {
  id         String   @id @default(cuid())
  patientId  String
  date       DateTime
  weightKg   Decimal? @db.Decimal(6, 2)
  bodyFatPct Decimal? @db.Decimal(5, 2)
  waistCm    Decimal? @db.Decimal(6, 2)
  hipCm      Decimal? @db.Decimal(6, 2)
  notes      String?
  createdAt  DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, date])
}

model Anamnesis {
  id        String   @id @default(cuid())
  patientId String
  type      String
  answers   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model Recall {
  id             String    @id @default(cuid())
  organizationId String
  patientId      String
  referenceDate  DateTime?
  generalNotes   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  meals        RecallMeal[]

  @@index([organizationId, createdAt])
  @@index([patientId, referenceDate])
}

model RecallMeal {
  id       String  @id @default(cuid())
  recallId String
  type     String
  label    String
  time     String?
  position Int     @default(0)
  notes    String?

  recall Recall           @relation(fields: [recallId], references: [id], onDelete: Cascade)
  items  RecallMealItem[]

  @@index([recallId])
}

model RecallMealItem {
  id           String   @id @default(cuid())
  recallMealId String
  foodId       String?
  foodName     String
  portion      String
  quantity     Decimal  @db.Decimal(8, 2)
  calories     Decimal  @db.Decimal(8, 2)
  protein      Decimal  @db.Decimal(8, 2)
  carbs        Decimal  @db.Decimal(8, 2)
  fat          Decimal  @db.Decimal(8, 2)
  fiber        Decimal? @db.Decimal(8, 2)
  notes        String?

  meal RecallMeal @relation(fields: [recallMealId], references: [id], onDelete: Cascade)

  @@index([recallMealId])
  @@index([foodId])
}

model LabExam {
  id             String   @id @default(cuid())
  organizationId String
  patientId      String
  examDate       DateTime
  laboratoryName String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  results      LabExamResult[]

  @@index([organizationId, examDate])
  @@index([patientId, examDate])
}

model LabExamResult {
  id             String  @id @default(cuid())
  labExamId      String
  category       String
  name           String
  value          Decimal @db.Decimal(10, 3)
  unit           String
  referenceRange String?
  interpretation String?

  labExam LabExam @relation(fields: [labExamId], references: [id], onDelete: Cascade)

  @@index([labExamId])
  @@index([name])
}

model SupplementPrescription {
  id             String   @id @default(cuid())
  organizationId String
  patientId      String
  prescribedAt   DateTime @default(now())
  duration       String?
  generalNotes   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient                      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  items        SupplementPrescriptionItem[]

  @@index([organizationId, prescribedAt])
  @@index([patientId, prescribedAt])
}

model SupplementPrescriptionItem {
  id             String  @id @default(cuid())
  prescriptionId String
  name           String
  category       String
  dose           String
  frequency      String?
  timing         String?
  instructions   String?
  position       Int     @default(0)

  prescription SupplementPrescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
  @@index([category])
}

model FoodDiaryEntry {
  id             String          @id @default(cuid())
  organizationId String
  patientId      String
  mealType       String
  entryDate      DateTime
  entryTime      String?
  description    String
  photoUrl       String?
  status         FoodDiaryStatus @default(PENDING)
  feedbackNote   String?
  feedbackAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([organizationId, entryDate])
  @@index([patientId, entryDate])
  @@index([organizationId, status])
}

model HydrationLog {
  id             String   @id @default(cuid())
  organizationId String
  patientId      String
  date           DateTime
  time           String?
  amountMl       Int
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([organizationId, date])
  @@index([patientId, date])
}

model PatientGoal {
  id             String    @id @default(cuid())
  organizationId String
  patientId      String
  title          String
  target         Decimal   @db.Decimal(10, 2)
  current        Decimal   @default(0) @db.Decimal(10, 2)
  unit           String?
  dueDate        DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([patientId, completedAt])
}

model ChatMessage {
  id                   String     @id @default(cuid())
  organizationId       String
  patientId            String
  sender               ChatSender
  text                 String
  attachmentUrl        String?
  attachmentType       String?
  readByProfessionalAt DateTime?
  readByPatientAt      DateTime?
  createdAt            DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([patientId, createdAt])
  @@index([organizationId, readByProfessionalAt])
}

model EnergyCalculation {
  id                     String   @id @default(cuid())
  organizationId         String
  patientId              String
  formula                String
  sex                    Sex
  age                    Int
  weightKg               Decimal  @db.Decimal(6, 2)
  heightCm               Decimal  @db.Decimal(6, 2)
  activityFactor         Decimal  @db.Decimal(4, 3)
  basalMetabolicRate     Decimal  @db.Decimal(8, 2)
  totalEnergyExpenditure Decimal  @db.Decimal(8, 2)
  notes                  String?
  createdAt              DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([patientId, createdAt])
}

model EducationalMaterial {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  category       String
  audience       String?
  description    String?
  content        String?
  designUrl      String?
  imageUrl       String?
  tags           String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, category])
}

model FinancialTransaction {
  id             String            @id @default(cuid())
  organizationId String
  patientId      String?
  type           TransactionType
  status         TransactionStatus @default(PENDING)
  description    String
  amountCents    Int
  dueDate        DateTime
  paidAt         DateTime?
  paymentMethod  String?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient?     @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([organizationId, dueDate])
  @@index([organizationId, status])
  @@index([patientId])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entity         String
  entityId       String?
  metadata       Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entity, entityId])
}
